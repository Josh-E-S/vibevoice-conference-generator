# Gitignore for Conference-Generator-VibeVoice
# Ignore common build/dependency directories
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
build/
dist/
*.egg-info/
.tox/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Ignore editor/IDE files
.vscode/
.idea/
*.swp
*~
.DS_Store

# Ignore Modal-specific files
.modal.json
.modalignore
.modal/

# Ignore local data/logs
*.log
data/
tmp/

# Ignore sensitive files
.env
.env.*
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks
*.secret
*.token

# Ignore backend_modal directory for Hugging Face Space deployment
backend_modal/

# Ignore large local model backups (multi-GB .pt files)
vibevoice_local_backup/

# Ignore local Modal scratch scripts
check_model.py
run_phase3.py

# Large sample media hosted externally via GitHub user-attachments CDN
public/sample-generations/*.mp4
public/sample-generations/*.wav
